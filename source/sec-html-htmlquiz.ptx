        </choice>
        <choice>
          <statement>
            <p>&lt;ul&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;list&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;ol&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="html_quiz_q9">
      <statement>
        <p>Q-9: What is the correct HTML for inserting an image?</p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>&lt;image src="image.gif" alt="MyImage"&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;img href="image.gif" alt="MyImage"&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;img src="image.gif" alt="MyImage"&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;img alt="MyImage"&gt;image.gif&lt;/img&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="html_quiz_q10">
      <statement>
        <p>Q-10: Block elements are normally displayed without starting a new line.</p>
      </statement>
      <choices>
        <choice correct="yes">
          <statement>
            <p>False</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>True</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="html_quiz_q11">
      <statement>
        <p>Q-11: Which HTML element defines the title of a document?</p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>&lt;meta&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;head&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;title&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;h1&gt;</p>
          </statement>
          <feedback>
            <p>None</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
  </exercises>
  <p>Once you have completed the quiz you can review your answers but you will not be able to change them.</p>
