    </ol>
  </p>
  <exercise label="ex_js_6">
    <statement>
      <p>Starting with the code given, create a page that looks like the following image:  The rest of the page must be created using javascript.  You must use <c>document.createElement</c> and the <c>appendChild</c> functions.</p>
      <image source="cePage.png" width="350px%"/>
    </statement>
    <listing>
    <program xml:id="ex_js_6_editor" interactive="activecode" language="html" label="ex_js_6_editor">
      <input>
&lt;html&gt;
&lt;body&gt;
&lt;button onclick="makePage();"&gt;Click Here&lt;/button&gt;
&lt;/body&gt;

&lt;/html&gt;
        </input>
      <tests>


</tests>
    </program>
  </listing>
  </exercise>
