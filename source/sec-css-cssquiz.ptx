<?xml version="1.0"?>
<section xml:id="css_quiz-two">
  <title>Quiz Two</title>
  <exercises line="6" runestone_options="{'timelimit': 20, 'subchapter': 'cssquiz', 'chapter': 'CSS', 'basecourse': 'webfundamentals', 'optional': '', 'optclass': '', 'divid': 'css_quiz_1', 'qnumber': '', 'question_label': '4.4.1'}" source="/Users/lynn5/WebDevBook/webfundamentals/_sources/CSS/cssquiz.rst">
    <exercise label="q1_1">
      <statement>
        <p>Q-1: Which of the following are HTML block elements.  Select all that apply.</p>
      </statement>
      <choices>
        <choice correct="yes">
          <statement>
            <p>&lt;h1&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;img&gt;</p>
          </statement>
          <feedback>
            <p>No, an img tag is an inline element</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;li&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="q1_2">
      <statement>
        <p>Q-2: What is the protocol used in the URL:  <c>http://interactivepython.org/index.html</c></p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>File Transfer Protocol</p>
          </statement>
          <feedback>
            <p>No, FTP is not related to this class.</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>HyperText Markup Language</p>
          </statement>
          <feedback>
            <p>No, HTML is the markup language not the protocol</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>Secure Sockets Layer</p>
          </statement>
          <feedback>
            <p>No, SSL is not used</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>HyperText Transfer Protocol</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <p>In the following question, select all of the correct answers for each question.</p>
    <exercise label="q1_3">
      <statement>
        <p>Q-3: Which of the following will match the CSS selector <c>.high</c></p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>&lt;h1 class="low"&gt;Hello World&lt;/h1&gt;</p>
          </statement>
          <feedback>
            <p>This h1 has low class</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p class="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;p&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>No, the paragraph tag is just a plain paragraph with no class</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;li class="high"&gt;do my homework&lt;/li&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;p id="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>No the selector is matching the class not the id.</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="q1_4">
      <statement>
        <p>Q-4: Which of the following will match the CSS selector <c>p.high</c></p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>&lt;h1 class="low"&gt;Hello World&lt;/h1&gt;</p>
          </statement>
          <feedback>
            <p>This h1 has low class</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p class="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;p&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>No, the paragraph tag is just a plain paragraph with no class</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;li class="high"&gt;do my homework&lt;/li&gt;</p>
          </statement>
          <feedback>
            <p>No, this is an li tag</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;p id="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>No, this selector is looking for a paragraph with a class of high</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="q1_5">
      <statement>
        <p>Q-5: Which of the following will match the CSS selector <c>p</c></p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>&lt;h1 class="low"&gt;Hello World&lt;/h1&gt;</p>
          </statement>
          <feedback>
            <p>No this is an h1 tag</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p class="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;li class="high"&gt;do my homework&lt;/li&gt;</p>
          </statement>
          <feedback>
            <p>No, this is an li tag</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p id="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="q1_6">
      <statement>
        <p>Q-6: Which of the following will match the CSS selector <c>#high</c></p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>&lt;h1 class="low"&gt;Hello World&lt;/h1&gt;</p>
          </statement>
          <feedback>
            <p>No this is an h1 tag</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;p class="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>No, this selector is matching the id attribute</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;p&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>No, this selector is looking for an id</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>&lt;li class="high"&gt;do my homework&lt;/li&gt;</p>
          </statement>
          <feedback>
            <p>No, this selector is matching on the id not the class</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>&lt;p id="high"&gt;some text&lt;/p&gt;</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
    <exercise label="q1_7">
      <statement>
        <p>Q-7: Which of the following are properties of the CSS Box Model</p>
      </statement>
      <choices>
        <choice>
          <statement>
            <p>height</p>
          </statement>
          <feedback>
            <p>No height is an attribute of the content</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>padding</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>border</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice correct="yes">
          <statement>
            <p>margin</p>
          </statement>
          <feedback>
            <p>Yes</p>
          </feedback>
        </choice>
        <choice>
          <statement>
            <p>background-color</p>
          </statement>
          <feedback>
            <p>No, background-color is not part of the box model</p>
          </feedback>
        </choice>
      </choices>
    </exercise>
  </exercises>
  <p>When you have finished the above question, click on the Show button below to reveal two additional exercises.</p>
